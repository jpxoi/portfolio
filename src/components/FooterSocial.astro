---
import { footerSocialData } from '../data/socials'
---

<ul class='footer__social'>
  {
    footerSocialData.map((social) => (
      <li>
        <a href={social.link} target='_blank' rel='noreferrer' class='footer__social-link' aria-label={social.alt}>
          <i class={social.icon} />
          <span class='hidden'>{social.alt}</span>
        </a>
      </li>
    ))
  }
</ul>
