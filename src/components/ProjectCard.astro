---
import { Image } from 'astro:assets'
import Badge from './Badge.astro'
import type { Project } from '../types'
import { STATIC_CONTENT_URL } from '../constants'

interface Props extends Project {}

const { id, title, description, link, github, stack } = Astro.props

const img = `${STATIC_CONTENT_URL}/media/images/projects/${id}.webp`
const hasLiveLink = Boolean(link)
const hasGithubLink = Boolean(github)
const isPrivate = !hasLiveLink && !hasGithubLink
---

<div
  class='group project__card flex h-full w-full flex-col gap-6 rounded-lg p-4! transition-all duration-200 ease-in-out hover:scale-102 hover:shadow-sm'
>
  <div class='flex flex-1 flex-col gap-3'>
    <div class='relative overflow-hidden rounded-lg'>
      <Image
        src={img}
        alt={title}
        width={1920}
        height={1080}
        class='h-full w-full rounded-lg object-cover transition-opacity duration-200 ease-in-out group-hover:opacity-50'
      />

      {
        !isPrivate ? (
          <div class='absolute inset-0 flex items-center justify-center gap-3 opacity-0 transition-opacity duration-200 ease-in-out group-hover:opacity-100'>
            {link && (
              <a
                href={link}
                target='_blank'
                rel='noreferrer'
                aria-label={`Open live project: ${title}`}
                class='flex size-10 items-center justify-center rounded-full border border-white/20 bg-black/40 text-white backdrop-blur-sm transition-transform duration-200 ease-in-out hover:scale-110'
              >
                <i class='bx bx-globe text-xl' />
              </a>
            )}

            {github && (
              <a
                href={github}
                target='_blank'
                rel='noreferrer'
                aria-label={`Open GitHub repository: ${title}`}
                class='flex size-10 items-center justify-center rounded-full border border-white/20 bg-black/40 text-white backdrop-blur-sm transition-transform duration-200 ease-in-out hover:scale-110'
              >
                <i class='bxl bx-github text-xl' />
              </a>
            )}
          </div>
        ) : (
          <div class='absolute inset-0 flex items-center justify-center opacity-0 transition-opacity duration-200 ease-in-out group-hover:opacity-100'>
            <span class='rounded-full border border-white/20 bg-black/40 px-3! py-1! text-xs font-medium text-white backdrop-blur-sm'>
              Private Project
            </span>
          </div>
        )
      }
    </div>

    <div class='flex flex-col gap-2'>
      <div class='flex items-center gap-2'>
        <h3 class='text-foreground line-clamp-1 text-xl font-medium'>{title}</h3>

        {
          isPrivate && (
            <span class='rounded-full border border-gray-700 px-2! py-0.5! text-[10px] font-medium text-gray-400'>
              Private
            </span>
          )
        }
      </div>

      <p class='text-foreground line-clamp-4 text-sm text-gray-400'>{description}</p>
    </div>
  </div>

  <div class='flex flex-wrap gap-2'>
    {stack.map((stackItem) => <Badge text={stackItem} />)}
  </div>
</div>
