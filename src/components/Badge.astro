---
interface Props {
  text: string
}
const { text } = Astro.props

const hoverColors: Record<string, string> = {
  HTML: 'group-hover:text-[#e34f26]',
  CSS: 'group-hover:text-[#264de4]',
  CLI: 'group-hover:text-[#34A853]',
  JavaScript: 'group-hover:text-[#f7df1e]',
  TypeScript: 'group-hover:text-[#3178C6]',
  React: 'group-hover:text-[#61DAFB]',
  ReactJS: 'group-hover:text-[#61DAFB]',
  Python: 'group-hover:text-[#4584b6]',
  PostgreSQL: 'group-hover:text-[#336791]',
  Redis: 'group-hover:text-[#DC382D]',
  LLMs: 'group-hover:text-[#5F6368]',
  LLM: 'group-hover:text-[#5F6368]',
  TailwindCSS: 'group-hover:text-[#06b6d4]',
  Astro: 'group-hover:text-[#D83333]',
  TursoDB: 'group-hover:text-[#4FF8D2]',
  Vite: 'group-hover:text-[#646CFF]',
  Hono: 'group-hover:text-[#FF5B11]',
  Clerk: 'group-hover:text-[#6C47FF]',
  Cloudflare: 'group-hover:text-[#F48120]',
  'Drizzle ORM': 'group-hover:text-[#C5F74F]',
  Gemini: 'group-hover:text-[#4285F4]',
}
const hoverClass = hoverColors[text] ?? 'group-hover:text-foreground/90'

const monoStackIds = new Set(['NextJS', 'OpenAI', 'Ollama'])
const monoClass = monoStackIds.has(text) ? 'stack-badge--brand-mono' : ''
---

<span
  class={`max-w-max inline-block rounded-full px-2 py-0.5 text-xs font-bold uppercase tracking-normal ${monoClass || hoverClass}`}
>
  {text}
</span>
